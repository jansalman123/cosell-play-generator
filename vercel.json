{
  "functions": {
    "api/analyze.ts": {
      "maxDuration": 60
    },
    "api/documents.ts": {
      "maxDuration": 60
    },
    "api/playbook.ts": {
      "maxDuration": 60
    },
    "api/slides.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
